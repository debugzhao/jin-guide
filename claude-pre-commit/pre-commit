#!/bin/bash
# ============================================================================
# Claude Code Security Review - Pre-commit Hook
# 通用模板：在 git commit 前调用 Claude API 审查代码安全漏洞
# ============================================================================

set -euo pipefail

# ============================================================================
# 依赖检查
# ============================================================================

if ! command -v curl &> /dev/null; then
  echo "[Claude Review] 错误: curl 未安装" >&2
  exit 1
fi

# ============================================================================
# 环境检测与配置加载
# ============================================================================

IS_WINDOWS=false
if [[ "$(uname -s)" == MINGW* || "$(uname -s)" == MSYS* ]]; then
  IS_WINDOWS=true
fi

# --------------------------------------------------------------------------
# 1) 检查 Git 和 Git Bash（合并检测）
# --------------------------------------------------------------------------

GIT_CMD="git"

# Windows 下同步检测 Git Bash（从 git 所在目录推断 bash.exe）
if [ "$IS_WINDOWS" = true ] && [ -z "${CLAUDE_CODE_GIT_BASH_PATH:-}" ]; then
  GIT_DIR="$(dirname "$(command -v git)")"

  if [ -f "$GIT_DIR/bash.exe" ]; then
    export CLAUDE_CODE_GIT_BASH_PATH="$(cygpath -w "$GIT_DIR/bash.exe")"
  elif [ -f "$GIT_DIR/../bin/bash.exe" ]; then
    export CLAUDE_CODE_GIT_BASH_PATH="$(cygpath -w "$GIT_DIR/../bin/bash.exe")"
  elif command -v bash &> /dev/null; then
    export CLAUDE_CODE_GIT_BASH_PATH="$(cygpath -w "$(command -v bash)")"
  fi
fi

# 项目根目录
REPO_ROOT="$("$GIT_CMD" rev-parse --show-toplevel)"

# --------------------------------------------------------------------------
# 2) 加载外部配置文件
# --------------------------------------------------------------------------

SCRIPT_CONFIG="$REPO_ROOT/claude-pre-commit/config.sh"
if [ -f "$SCRIPT_CONFIG" ]; then
  source "$SCRIPT_CONFIG"
fi

# 加载后用 config.sh 覆盖（如果用户手动指定了路径）
if [ "$IS_WINDOWS" = true ] && [ -n "${CLAUDE_GIT_BASH_PATH:-}" ]; then
  export CLAUDE_CODE_GIT_BASH_PATH="$CLAUDE_GIT_BASH_PATH"
fi

# 最终检查 Git Bash（仅 Windows 必须有）
if [ "$IS_WINDOWS" = true ] && [ -z "${CLAUDE_CODE_GIT_BASH_PATH:-}" ]; then
  echo "[Claude Review] 错误: Git Bash 未找到" >&2
  echo "  解决方式: 在 claude-pre-commit/config.sh 中设置 CLAUDE_GIT_BASH_PATH" >&2
  exit 1
fi

# --------------------------------------------------------------------------
# 3) 检查 API 配置
# --------------------------------------------------------------------------

if [ -z "${CLAUDE_API_BASE_URL:-}" ] || [ -z "${CLAUDE_API_KEY:-}" ]; then
  echo "[Claude Review] 错误: API 配置缺失" >&2
  echo "  请在 claude-pre-commit/config.sh 中设置 CLAUDE_API_BASE_URL 和 CLAUDE_API_KEY" >&2
  exit 1
fi

# ============================================================================
# 应用其他配置（带默认值）
# ============================================================================

# 规则配置文件路径
CONFIG_FILE="$REPO_ROOT/${REVIEW_CONFIG_PATH:-claude-pre-commit/.claude-review.yml}"

# 失败策略
FAILURE_ACTION="${ON_FAILURE:-skip}"

# 颜色输出
if [ "${COLOR_OUTPUT:-true}" = "true" ]; then
  RED='\033[0;31m'
  YELLOW='\033[1;33m'
  GREEN='\033[0;32m'
  CYAN='\033[0;36m'
  NC='\033[0m'
else
  RED='' YELLOW='' GREEN='' CYAN='' NC=''
fi

# ============================================================================
# 辅助函数
# ============================================================================

log_info() { echo -e "${CYAN}[Claude Review]${NC} $1"; }
log_pass() { echo -e "${GREEN}[Claude Review] PASS${NC} $1"; }
log_warn() { echo -e "${YELLOW}[Claude Review] WARN${NC} $1"; }
log_block() { echo -e "${RED}[Claude Review] BLOCK${NC} $1"; }

# ============================================================================
# 配置读取（简易 YAML 解析）
# ============================================================================

get_config_value() {
  local key="$1"
  local default="$2"
  if [ -f "$CONFIG_FILE" ]; then
    local value
    value=$(grep "^${key}:" "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/^[^:]*:\s*//' | tr -d '"' | tr -d "'" | tr -d '\r' | xargs)
    echo "${value:-$default}"
  else
    echo "$default"
  fi
}

# 读取配置
MAX_DIFF_LINES=$(get_config_value "max_diff_lines" "500")
TIMEOUT=$(get_config_value "timeout" "60")
LANGUAGE=$(get_config_value "language" "中文")
SEVERITY=$(get_config_value "severity" "strict")

# ============================================================================
# 前置检查
# ============================================================================

# 获取暂存区基准
if "$GIT_CMD" rev-parse --verify HEAD >/dev/null 2>&1; then
  AGAINST=HEAD
else
  AGAINST=$("$GIT_CMD" hash-object -t tree /dev/null)
fi

# 获取变更文件列表
CHANGED_FILES=$("$GIT_CMD" diff --cached --name-only --diff-filter=ACMR "$AGAINST")

if [ -z "$CHANGED_FILES" ]; then
  exit 0
fi

# ============================================================================
# 文件过滤（基于 ignore 配置）
# ============================================================================

filter_files() {
  local files="$1"
  local filtered=""

  local ignore_patterns=""
  if [ -f "$CONFIG_FILE" ]; then
    ignore_patterns=$(awk '/^ignore:/,/^[^ #-]/' "$CONFIG_FILE" | grep '^\s*-' | sed 's/^\s*-\s*//' | tr -d '"' | tr -d "'")
  fi

  while IFS= read -r file; do
    local skip=false
    if [ -n "$ignore_patterns" ]; then
      while IFS= read -r pattern; do
        if [[ -n "$pattern" ]] && echo "$file" | grep -qE "$pattern" 2>/dev/null; then
          skip=true
          break
        fi
      done <<< "$ignore_patterns"
    fi
    if [ "$skip" = false ]; then
      filtered="${filtered}${file}"$'\n'
    fi
  done <<< "$files"

  echo "$filtered" | sed '/^$/d'
}

FILTERED_FILES=$(filter_files "$CHANGED_FILES")

if [ -z "$FILTERED_FILES" ]; then
  log_info "所有变更文件已被 ignore 规则排除，跳过审查"
  exit 0
fi

# ============================================================================
# 获取 Diff 内容
# ============================================================================

DIFF=$("$GIT_CMD" diff --cached "$AGAINST" -- $FILTERED_FILES)

DIFF_LINES=$(echo "$DIFF" | wc -l)
if [ "$DIFF_LINES" -gt "$MAX_DIFF_LINES" ]; then
  log_warn "Diff 行数 ($DIFF_LINES) 超过阈值 ($MAX_DIFF_LINES)，跳过审查"
  exit 0
fi

# ============================================================================
# 构建审查 Prompt
# ============================================================================

RULES_CONTENT=""
if [ -f "$CONFIG_FILE" ]; then
  RULES_CONTENT=$(cat "$CONFIG_FILE")
fi

REVIEW_INSTRUCTIONS="你是一个代码安全审查专家。请审查以下 git diff 中的安全漏洞。

## 审查严格程度: ${SEVERITY}

## 审查规则配置:
${RULES_CONTENT:-使用 OWASP Top 10 默认规则}

## 输出格式要求（严格遵守）:
- 如果发现必须阻止提交的严重安全漏洞，每个问题输出一行: BLOCK: [文件名] - [漏洞描述]
- 如果发现需要关注但不阻止提交的问题，每个问题输出一行: WARN: [文件名] - [问题描述]
- 如果没有安全问题，仅输出一个词: PASS
- 不要输出任何其他内容，不要解释，不要markdown格式

## 输出语言: ${LANGUAGE}"

# ============================================================================
# 调用 Claude API 审查
# ============================================================================

log_info "正在审查 $(echo "$FILTERED_FILES" | wc -l | xargs) 个文件的安全性..."

# JSON 转义函数（通过 sed 处理所有特殊字符）
json_escape() {
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/\t/\\t/g' | \
    awk '{if(NR>1) printf "\\n"; printf "%s", $0}'
}

# 构建请求 JSON，写入临时文件避免 shell 转义问题
TMPFILE=$(mktemp)
trap "rm -f $TMPFILE" EXIT

ESCAPED_SYSTEM=$(json_escape "$REVIEW_INSTRUCTIONS")
ESCAPED_DIFF=$(json_escape "$DIFF")
MODEL="${CLAUDE_MODEL:-claude-haiku-4-5-20251001}"

cat > "$TMPFILE" <<EOFBODY
{"model":"${MODEL}","max_tokens":1024,"system":"${ESCAPED_SYSTEM}","messages":[{"role":"user","content":"${ESCAPED_DIFF}"}]}
EOFBODY

# 调用 API（用 curl 自带的 --max-time 做超时控制，不依赖外部 timeout/gtimeout 命令——
# macOS 默认不带 GNU coreutils 的 timeout，装了 coreutils 也叫 gtimeout，直接调用 timeout 会
# 因为 "command not found" 在 set -e 下让整个 hook 静默退出，导致 commit 被无提示地阻断）
# curl 请求失败（网络不通/DNS 失败/超时等）时返回非零退出码；用 || true 吞掉，避免在
# set -e 下让脚本在这里直接静默终止——把失败交给下面的 HTTP_CODE 判断走 ON_FAILURE 策略处理，
# 而不是绕过所有错误处理直接把 commit 无提示地卡死。
API_RESPONSE=$(curl -s -w "\n%{http_code}" --max-time "${TIMEOUT}" \
  "${CLAUDE_API_BASE_URL}/v1/messages" \
  -H "Content-Type: application/json" \
  -H "x-api-key: ${CLAUDE_API_KEY}" \
  -H "anthropic-version: 2023-06-01" \
  -d @"$TMPFILE" 2>&1) || true

# 提取 HTTP 状态码和响应体
HTTP_CODE=$(echo "$API_RESPONSE" | tail -1)
RESPONSE_BODY=$(echo "$API_RESPONSE" | sed '$d')

# 错误处理
if [ "$HTTP_CODE" != "200" ]; then
  RESULT="ERROR: API 返回 HTTP $HTTP_CODE - $RESPONSE_BODY"
else
  # 提取 content[0].text（无 jq，用 grep/sed 解析）
  RESULT=$(echo "$RESPONSE_BODY" | grep -o '"text":"[^"]*"' | head -1 | sed 's/"text":"//;s/"$//')
  # 还原转义的换行符
  RESULT=$(echo -e "$RESULT")
  if [ -z "$RESULT" ]; then
    RESULT="ERROR: 无法解析 API 响应"
  fi
fi

# ============================================================================
# 解析结果
# ============================================================================

if echo "$RESULT" | grep -q "^ERROR:"; then
  if [ "$FAILURE_ACTION" = "block" ]; then
    log_block "Claude 审查失败，阻断提交: ${RESULT#ERROR: }"
    exit 1
  else
    log_warn "Claude 审查失败，跳过（不阻断提交）: ${RESULT#ERROR: }"
    exit 0
  fi
fi

HAS_BLOCK=false
HAS_WARN=false

while IFS= read -r line; do
  if [[ "$line" == BLOCK:* ]]; then
    HAS_BLOCK=true
    log_block "${line#BLOCK: }"
  fi
done <<< "$RESULT"

while IFS= read -r line; do
  if [[ "$line" == WARN:* ]]; then
    HAS_WARN=true
    log_warn "${line#WARN: }"
  fi
done <<< "$RESULT"

# 最终判定
if [ "$HAS_BLOCK" = true ]; then
  echo ""
  log_block "提交已阻止！请修复上述安全问题后重试。"
  log_info "跳过检查: git commit --no-verify"
  exit 1
elif [ "$HAS_WARN" = true ]; then
  echo ""
  log_pass "审查通过（有警告，请关注上述建议）"
  exit 0
else
  log_pass "安全审查通过"
  exit 0
fi
